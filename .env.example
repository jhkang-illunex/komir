# dev/.env  (복사: cp .env.example .env, 커밋 금지)
# --- 정형 수집 키 ---
DATA_GO_KR_SERVICE_KEY_ENCODING=
DATA_GO_KR_SERVICE_KEY_DECODING=
ECOS_API_KEY=

# --- 지정학 LLM provider ---
LLM_PROVIDER=openai_compat          # rule | mock | openai_compat | anthropic
LLM_BASE_URL=http://host.docker.internal:11434/v1   # OpenAI: https://api.openai.com/v1
LLM_MODEL=qwen2.5:32b
LLM_API_KEY=
LLM_TEMPERATURE=0
PDF_MAXPAGES=40

# 공유 DB 경로(컨테이너 내부). 서버DB로 바꾸려면 SQLAlchemy URL 사용:
#   MSR_DB=mariadb+pymysql://user:pw@host:3306/mineral
#   GEO_PUBLISH_DB=oracle+oracledb://user:pw@host:1521/?service_name=ORCL
